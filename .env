# =============================================================================
# ESL Application - Environment Configuration
# =============================================================================
# Development defaults - copy this file and adjust for production
# =============================================================================

# Environment
APP_ENV=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite for development, change to PostgreSQL for production)
DATABASE_URL=sqlite:///esl.db
DATABASE_ECHO=false

# JWT Authentication
# IMPORTANT: Change this in production to a secure random string
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Excel Import
EXCEL_FILE_PATH=English_Learning_Data_Clean.xlsx
EXCEL_DATA_DIR=data

# SMTP / Email (for OTP delivery) - Optional for development
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_USE_TLS=true

# OTP Rate Limiting
OTP_RATE_LIMIT_PER_MINUTE=5

# OpenAI (Optional - AI service for chat, quiz generation)
# Use either OpenAI API OR local models (Ollama)
# OPENAI_API_KEY=sk-...                    # For OpenAI API
OPENAI_BASE_URL=http://localhost:11434/v1  # For Ollama/local models
OPENAI_MODEL=llama3.2:3b                   # Ollama model
# OPENAI_MAX_RETRIES=3
# OPENAI_TIMEOUT_SECONDS=30

# Google Cloud (Optional - TTS/STT)
# GOOGLE_CLOUD_CREDENTIALS_JSON={"type": "service_account", ...}
# GOOGLE_TTS_LANGUAGE_CODE=en-US
# GOOGLE_STT_LANGUAGE_CODE=en-US

# Firebase / FCM (Optional - Push Notifications)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}
# ADMIN_PUSH_KEY=your-fcm-key

# Social Login (Optional)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# File Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Notifications
NOTIFICATION_SCHEDULER_INTERVAL_MINUTES=60

# Audio
AUDIO_FILE_EXPIRY_HOURS=24